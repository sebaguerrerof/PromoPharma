rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /brands/{brandId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
    match /sessions/{sessionId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
    // Documents uploaded per indication (PDF, DOCX — up to 50 MB)
    match /tenants/{tenantId}/documents/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
    // Brochure source files (PDF, images — up to 20 MB)
    match /tenants/{tenantId}/brochures/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
    // Knowledge bank files (any type — up to 50 MB)
    match /knowledge/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
    // Mailing images (up to 10 MB)
    match /mailing/{tenantId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
